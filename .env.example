# .env.example - Copy to .env or .gitlabrc and fill in your values.
# Lines starting with # are comments. Inline comments are also supported.
# Values may be quoted or unquoted. Do not commit credentials to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Base URL of your GitLab instance (no trailing slash)
GITLAB_URL=https://gitlab.com          # GitLab.com (default)
# GITLAB_URL=https://gitlab.example.com  # Self-hosted

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Authentication scheme: pat (default) | bearer | basic | cookie
# GITLAB_AUTH_TYPE=pat

# --- PAT / token auth (pat or bearer) ---
GITLAB_TOKEN=your-personal-access-token

# --- Basic auth (username + password) ---
# GITLAB_AUTH_TYPE=basic
# GITLAB_USERNAME=your-username
# GITLAB_PASSWORD=your-password

# --- Session cookie auth ---
# GITLAB_AUTH_TYPE=cookie
# GITLAB_SESSION_COOKIE=value-of-_gitlab_session-cookie-from-browser

# ---------------------------------------------------------------------------
# Default scope (optional — can also be passed as CLI flags)
# ---------------------------------------------------------------------------

# Export a specific project by default
# GITLAB_PROJECT=your-group/your-project

# Export all projects in a group by default
# GITLAB_GROUP=your-group

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

# Directory where exported files are written (default: ./export)
# GITLAB_OUTPUT_DIR=./export

# Issue/MR state filter: all (default), opened, or closed
# GITLAB_STATE=all

# ---------------------------------------------------------------------------
# Behaviour
# ---------------------------------------------------------------------------

# Maximum number of API retry attempts on transient errors (default: 3)
# GITLAB_MAX_RETRIES=3

# Base delay in seconds between retries — doubles on each attempt (default: 5)
# GITLAB_RETRY_DELAY=5

# Items per page for API pagination (default: 100)
# GITLAB_PER_PAGE=100

# Set to 1 to enable verbose debug output
# GITLAB_DEBUG=0
